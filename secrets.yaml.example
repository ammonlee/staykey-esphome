# Copy this file to secrets.yaml and fill in your values
# cp secrets.yaml.example secrets.yaml

# Wi-Fi credentials
wifi_ssid: "YourNetworkName"
wifi_password: "YourWiFiPassword"

# ESPHome API encryption key
# Generate your own with: openssl rand -base64 32
api_encryption_key: "REPLACE_WITH_YOUR_BASE64_KEY"

# Fallback AP password (used when device can't connect to WiFi)
fallback_ap_password: "staykey123"
